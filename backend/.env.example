# ===========================================================================
# Configuração do backend (copie este arquivo para ".env" e ajuste se preciso)
# ===========================================================================

# Porta em que a API Express vai rodar
PORT=3000

# String de conexão do MongoDB.
# Padrão = MongoDB Community instalado localmente.
MONGODB_URI=mongodb://127.0.0.1:27017/copaApostas

# Se "true", ignora a MONGODB_URI e sobe um MongoDB EM MEMÓRIA automaticamente
# (não precisa instalar MongoDB). Útil para testar rápido. Os dados resetam
# a cada reinício do servidor.
USE_MEMORY_DB=false

# Segredo usado para assinar os tokens JWT de autenticação
JWT_SECRET=troque-este-segredo-em-producao

# Tempo de expiração do token
JWT_EXPIRES_IN=7d

# Origem permitida para CORS (URL do frontend Angular)
CORS_ORIGIN=http://localhost:4200
